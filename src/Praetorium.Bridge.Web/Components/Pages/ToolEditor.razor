@implements IAsyncDisposable
@using Praetorium.Bridge.Agents
@using Praetorium.Bridge.Configuration
@using Praetorium.Bridge.Web.Services
@inject ConfigurationService ConfigService
@inject IAgentProvider AgentProvider

<div class="tool-editor">
    <div class="editor-header">
        <div class="editor-header-text">
            <h2>@ToolName</h2>
            @if (Tool != null)
            {
                <textarea class="tool-description-input"
                          rows="4"
                          placeholder="Describe what this tool does (shown to the LLM)…"
                          @bind="Tool.Description"
                          @bind:event="oninput"></textarea>
            }
        </div>
        <div class="header-actions stacked">
            <button class="save-button" @onclick="SaveAsync">Save</button>
            <button class="delete-button" @onclick="ConfirmDelete" title="Delete tool">Delete</button>
        </div>
    </div>

    @if (showDeleteConfirm)
    {
        <div class="delete-confirm">
            <span>Are you sure you want to delete this tool?</span>
            <div class="confirm-actions">
                <button class="cancel-button" @onclick="CancelDelete">Cancel</button>
                <button class="delete-button" @onclick="DeleteAsync">Delete</button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(SaveStatus))
    {
        <div class="status-message @(SaveStatus.StartsWith("Error") ? "error" : "success")">
            @SaveStatus
        </div>
    }

    <div class="editor-tabs">
        <div class="tab-group">
            <button class="tab @(activeTab == "parameters" ? "active" : "")" @onclick='() => SetActiveTabAsync("parameters")'>
                Parameters & Prompt
            </button>
            <button class="tab @(activeTab == "agent" ? "active" : "")" @onclick='() => SetActiveTabAsync("agent")'>
                Agent Config
            </button>
            <button class="tab @(activeTab == "session" ? "active" : "")" @onclick='() => SetActiveTabAsync("session")'>
                Session Config
            </button>
            <button class="tab @(activeTab == "signaling" ? "active" : "")" @onclick='() => SetActiveTabAsync("signaling")'>
                Signaling
            </button>
        </div>
    </div>

    <div class="tab-content">
        @* ==================== PARAMETERS + PROMPT TAB ==================== *@
        @if (activeTab == "parameters")
        {
            <div class="section">
                <div class="section-header">
                    <h3>Tool Parameters</h3>
                    <button class="add-button" @onclick="ShowAddParameter" title="Add parameter">+ Add Parameter</button>
                </div>

                @if (showAddParameterForm)
                {
                    <div class="add-form">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Name:</label>
                                <input type="text" @bind="newParamName" class="form-input" placeholder="e.g., userId" />
                            </div>
                            <div class="form-group">
                                <label>Type:</label>
                                <select @bind="newParamType" class="form-input">
                                    <option value="string">string</option>
                                    <option value="number">number</option>
                                    <option value="integer">integer</option>
                                    <option value="boolean">boolean</option>
                                    <option value="object">object</option>
                                    <option value="array">array</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="newParamRequired" />
                                    Required
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Description:</label>
                            <input type="text" @bind="newParamDescription" class="form-input" placeholder="Describe what this parameter does..." />
                        </div>
                        @if (!string.IsNullOrEmpty(paramError))
                        {
                            <div class="status-message error">@paramError</div>
                        }
                        <div class="form-actions">
                            <button class="cancel-button" @onclick="CancelAddParameter">Cancel</button>
                            <button class="save-button" @onclick="AddParameter">Add</button>
                        </div>
                    </div>
                }

                @if (Tool?.Parameters != null && Tool.Parameters.Count > 0)
                {
                    <div class="params-list">
                        @foreach (var param in Tool.Parameters)
                        {
                            var isManaged = IsReferenceIdParameter(param.Key);
                            <div class="param-item @(isManaged ? "param-item--managed" : "")">
                                <div class="param-header">
                                    <div class="param-name">@param.Key</div>
                                    <div class="param-badges">
                                        <span class="param-type">@param.Value.Type</span>
                                        @if (param.Value.Required)
                                        {
                                            <span class="param-required">required</span>
                                        }
                                        @if (isManaged)
                                        {
                                            <span class="param-managed" title="Auto-managed: used for session routing and filtered before the agent receives the call">managed</span>
                                        }
                                    </div>
                                    @if (!isManaged)
                                    {
                                        <button class="remove-button" @onclick="() => RemoveParameter(param.Key)" title="Remove parameter">×</button>
                                    }
                                </div>
                                @if (isManaged)
                                {
                                    <div class="managed-description-row">
                                        <input type="text" @bind="param.Value.Description" class="form-input param-description-input"
                                               placeholder="Describe what this parameter does…" />
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(param.Value.Description))
                                {
                                    <div class="param-description">@param.Value.Description</div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state">No parameters defined. Click "Add Parameter" to define input parameters for this tool.</p>
                }
            </div>

            <div class="section prompt-section">
                <div class="section-header">
                    <h3>System Prompt</h3>
                </div>
                <p class="section-description">
                    Static instructions installed on the agent's session at creation time — typically a short
                    description of the tool-calling conventions. Leave as <strong>Default</strong> to inherit from
                    <code>defaults.systemPrompt</code>. Inline content and a prompt file are mutually exclusive.
                </p>

                <div class="form-group">
                    <label>Source:</label>
                    <select value="@SystemPromptMode" @onchange="OnSystemPromptModeChangedAsync" class="form-input">
                        <option value="default">Default (inherit from defaults.systemPrompt)</option>
                        <option value="inline">Inline content</option>
                        <option value="file">Prompt file</option>
                    </select>
                </div>

                @if (SystemPromptMode == "inline")
                {
                    <div class="form-group">
                        <textarea class="form-textarea" rows="6"
                                  value="@(Tool!.SystemPrompt?.Content ?? string.Empty)"
                                  @onchange="OnSystemPromptContentChanged"
                                  placeholder="You are a bridged agent. Respond exclusively by calling the signaling tools..."></textarea>
                        <p class="field-hint">Kept verbatim and installed as the agent's system message.</p>
                    </div>
                }
                else if (SystemPromptMode == "file")
                {
                    <div class="form-group">
                        <label>Prompt File:</label>
                        <div class="inline-row">
                            <input type="text" value="@(Tool!.SystemPrompt?.PromptFile ?? string.Empty)"
                                   @onchange="OnSystemPromptFileChangedAsync"
                                   class="form-input" placeholder="@DefaultSystemPromptFilename()" />
                            @if (!SystemPromptFileExists())
                            {
                                <button type="button" class="save-button small"
                                        @onclick="CreateSystemPromptFileAsync"
                                        title="Create this file in the prompts directory">
                                    Create file
                                </button>
                            }
                        </div>
                        <p class="field-hint">Path relative to the prompts directory. The file contents are used verbatim — no templating.</p>
                        @if (!SystemPromptFileExists() && !string.IsNullOrWhiteSpace(Tool!.SystemPrompt?.PromptFile))
                        {
                            <p class="field-hint field-hint-warn">⚠ File does not exist yet. Click <strong>Create file</strong> to create it, or save to persist the empty file on disk.</p>
                        }
                        <textarea class="form-textarea" rows="6"
                                  value="@systemPromptFileContent"
                                  @onchange="OnSystemPromptFileContentChanged"
                                  placeholder="# System instructions..."></textarea>
                    </div>
                }
            </div>

            <div class="section prompt-section">
                <div class="section-header">
                    <h3>Tool Prompt</h3>
                </div>
                <p class="section-description">
                    Per-turn user message sent to the agent each time a fresh turn starts.
                    Reference parameters using <code>{{PLACEHOLDER_NAME}}</code>.
                </p>

                <div class="form-group">
                    <label>Prompt File:</label>
                    <input type="text" value="@(Tool!.Agent!.PromptFile ?? string.Empty)"
                           @onchange="OnPromptFilePathChangedAsync"
                           class="form-input" placeholder="@DefaultPromptFilename()" />
                    <p class="field-hint">Saved to the prompts directory. Leave blank to auto-generate from the tool name.</p>
                </div>

                <div class="prompt-editor-layout">
                    <div class="prompt-main">
                        <textarea class="form-textarea prompt-textarea" rows="18"
                                  value="@promptContent"
                                  @onchange="OnPromptContentChanged"
                                  placeholder="# @ToolName&#10;&#10;You are an agent that ..."></textarea>

                        @{
                            var unknown = FindUnknownPlaceholders();
                        }
                        @if (unknown.Count > 0)
                        {
                            <div class="placeholder-warn">
                                Unknown placeholder@(unknown.Count == 1 ? "" : "s"):
                                @string.Join(", ", unknown.Select(p => $"{{{{{p}}}}}"))
                            </div>
                        }
                    </div>

                    <aside class="prompt-sidebar">
                        <div class="sidebar-block">
                            <div class="sidebar-title">Insert parameter</div>
                            @if (AllPlaceholderSources().Count == 0)
                            {
                                <p class="sidebar-empty">Add a parameter above to insert it here.</p>
                            }
                            else
                            {
                                <div class="chip-list">
                                    @foreach (var name in AllPlaceholderSources())
                                    {
                                        <button type="button" class="chip"
                                                @onclick="() => InsertPlaceholder(name)"
                                                title="Insert {{@(ToPlaceholder(name))}}">
                                            @name
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <div class="sidebar-block">
                            <div class="sidebar-title">Detected placeholders</div>
                            @{
                                var detected = DetectedPlaceholders();
                            }
                            @if (detected.Count == 0)
                            {
                                <p class="sidebar-empty">None.</p>
                            }
                            else
                            {
                                <div class="chip-list">
                                    @foreach (var p in detected)
                                    {
                                        var known = IsKnownPlaceholder(p);
                                        <span class="chip @(known ? "known" : "unknown")">
                                            @FromPlaceholder(p)
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </aside>
                </div>
            </div>
        }

        @* ==================== AGENT CONFIG TAB ==================== *@
        @if (activeTab == "agent")
        {
            <div class="section">
                <h3>Agent Configuration</h3>

                <div class="form-group">
                    <label>Provider:</label>
                    <select @bind="Tool!.Agent!.Provider" class="form-input" disabled>
                        <option value="github-copilot">GitHub Copilot</option>
                    </select>
                    <p class="field-hint">Currently only GitHub Copilot (via Azure AI Foundry) is integrated.</p>
                </div>

                <div class="form-group">
                    <label>Model:</label>
                    @if (isLoadingModels)
                    {
                        <div class="models-loading">Loading available deployments...</div>
                    }
                    else if (availableModels.Count > 0)
                    {
                        <select value="@(Tool.Agent.Model ?? string.Empty)"
                                @onchange="OnModelChangedAsync" class="form-input">
                            <option value="">-- Select a deployment --</option>
                            @foreach (var m in availableModels)
                            {
                                <option value="@m">@m</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="text" value="@(Tool.Agent.Model ?? string.Empty)"
                               @onchange="OnModelChangedAsync" class="form-input" placeholder="e.g., gpt-4o" />
                        <p class="field-hint field-hint-warn">⚠ Could not retrieve deployments from Azure AI Foundry. Enter the deployment name manually.</p>
                    }
                    <p class="field-hint">The model deployment to use from your Azure AI Foundry project.</p>
                </div>

                <div class="form-group">
                    <label>Reasoning Effort:</label>
                    <p class="field-hint">Controls how deeply the model reasons. The available levels come from the selected model's capabilities.</p>
                    @if (isLoadingCapabilities)
                    {
                        <div class="models-loading">Checking model capabilities...</div>
                    }
                    else if (string.IsNullOrEmpty(Tool.Agent.Model))
                    {
                        <select class="form-input" disabled>
                            <option>Select a model first</option>
                        </select>
                    }
                    else if (selectedCapabilities?.SupportsReasoningEffort != true || selectedCapabilities.SupportedReasoningLevels.Count == 0)
                    {
                        <select class="form-input" disabled>
                            <option>Not supported by @Tool.Agent.Model</option>
                        </select>
                    }
                    else
                    {
                        <select @bind="Tool.Agent.ReasoningEffort" class="form-input">
                            <option value="">None (default)</option>
                            @foreach (var level in selectedCapabilities.SupportedReasoningLevels)
                            {
                                <option value="@level">@level</option>
                            }
                        </select>
                    }
                </div>

                <div class="form-group">
                    <div class="section-header">
                        <label>Allowed Tool Sources:</label>
                        <button class="add-button small" @onclick="ShowAddToolSource" title="Add tool source">+ Add</button>
                    </div>
                    <p class="field-hint">Agent tool sources that this tool's agent can use. These are defined in the agentToolSources configuration.</p>

                    @if (showAddToolSourceForm)
                    {
                        <div class="add-form inline">
                            <select @bind="selectedToolSourceToAdd" class="form-input">
                                <option value="">-- Select tool source --</option>
                                @foreach (var source in AvailableToolSources.Where(s => !Tool.Agent.Tools.Contains(s)))
                                {
                                    <option value="@source">@source</option>
                                }
                            </select>
                            <button class="save-button small" @onclick="AddToolSource">Add</button>
                            <button class="cancel-button small" @onclick="() => showAddToolSourceForm = false">Cancel</button>
                        </div>
                    }

                    @if (Tool.Agent.Tools != null && Tool.Agent.Tools.Count > 0)
                    {
                        <div class="tags-list">
                            @foreach (var toolRef in Tool.Agent.Tools)
                            {
                                <div class="tag">
                                    <span>@toolRef</span>
                                    <button class="tag-remove" @onclick="() => RemoveToolSource(toolRef)">×</button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-state small">No tool sources assigned.</p>
                    }
                </div>
            </div>
        }

        @* ==================== SESSION CONFIG TAB ==================== *@
        @if (activeTab == "session")
        {
            <div class="section">
                <h3>Session Configuration</h3>
                <p class="section-description">Configure how agent sessions are created and managed for this tool.</p>

                <div class="form-group">
                    <label>Session Mode:</label>
                    <select @bind="Tool!.Session!.Mode" @bind:after="OnSessionModeChanged" class="form-input">
                        <option value="@SessionMode.PerConnection">Per Connection</option>
                        <option value="@SessionMode.PerReference">Per Reference</option>
                        <option value="@SessionMode.Global">Global</option>
                    </select>
                    <div class="mode-explanation">
                        @switch (Tool.Session.Mode)
                        {
                            case SessionMode.PerConnection:
                                <p><strong>Per Connection:</strong> Creates a new session for each client connection. Sessions are isolated and do not share context. Best for independent, stateless operations.</p>
                                break;
                            case SessionMode.PerReference:
                                <p><strong>Per Reference:</strong> Sessions are pooled and reused based on a reference ID parameter. Multiple requests with the same reference share the same session. Best for maintaining context across related requests (e.g., same user, same project).</p>
                                break;
                            case SessionMode.Global:
                                <p><strong>Global:</strong> A single shared session is used for all connections. All requests share the same agent context. Best for shared knowledge bases or when coordination is needed.</p>
                                break;
                        }
                    </div>
                </div>

                @if (Tool.Session.Mode == SessionMode.PerReference)
                {
                    <div class="form-group">
                        <label>Reference ID Parameter:</label>
                        <input type="text"
                               value="@Tool.Session.ReferenceIdParameter"
                               @onchange="OnReferenceIdParameterNameChanged"
                               class="form-input" placeholder="e.g., userId, projectId" />
                        <p class="field-hint">The name of the tool parameter that contains the reference ID for session pooling. This parameter is automatically added to the Parameters tab and is <strong>filtered before the agent receives the call</strong> — it is used only for session routing.</p>
                    </div>
                }

                <div class="form-group">
                    <label>Pool Timeout (minutes):</label>
                    <input type="number" @bind="Tool.Session.PoolTimeoutMinutes" class="form-input" min="1" max="1440" />
                    <p class="field-hint">How long an idle pooled session remains available before being disposed. Sessions are kept warm for reuse within this window.</p>
                </div>

                <div class="form-group">
                    <label>Response Timeout (seconds):</label>
                    <input type="number" @bind="Tool.Session.ResponseTimeoutSeconds" class="form-input" min="10" max="3600" />
                    <p class="field-hint">Maximum time to wait for an agent response before timing out. Increase for long-running operations.</p>
                </div>
            </div>
        }

        @* ==================== SIGNALING TAB ==================== *@
        @if (activeTab == "signaling")
        {
            <SignalingToolsEditor @ref="signalingEditor"
                                  Signaling="Tool!.Signaling!"
                                  AvailablePromptFiles="availablePromptFiles"
                                  ToolName="ToolName" />
        }
    </div>
</div>

@code {
    [Parameter]
    public required ToolDefinition Tool { get; set; }

    [Parameter]
    public required string ToolName { get; set; }

    [Parameter]
    public required Func<Task> OnSave { get; set; }

    [Parameter]
    public Func<Task>? OnDelete { get; set; }

    [Parameter]
    public List<string> AvailableToolSources { get; set; } = new();

    private string activeTab = "parameters";
    private string SaveStatus = "";
    private bool showDeleteConfirm = false;

    // Model loading
    private List<string> availableModels = new();
    private bool isLoadingModels = false;
    private bool modelsLoaded = false;

    // Model capabilities (drives the reasoning-effort dropdown)
    private AgentCapabilities? selectedCapabilities;
    private bool isLoadingCapabilities = false;
    private string? loadedCapabilitiesFor;

    // Prompt files (for the signaling editor)
    private List<string> availablePromptFiles = new();

    // Inline system-prompt editor state
    private string promptContent = string.Empty;
    private string? loadedPromptFile;
    private bool promptDirty;

    // System-prompt (static, installed on the agent session) editor state.
    // SystemPromptMode is derived from Tool.SystemPrompt and drives which sub-editor is shown.
    private string SystemPromptMode = "default";
    private string systemPromptFileContent = string.Empty;
    private string? loadedSystemPromptFile;
    private bool systemPromptFileDirty;

    // Editor-local caches that survive mode toggles. Without these, switching
    // file <-> inline (or via 'default') would silently wipe the inactive field's
    // last value because the model only allows one of Content/PromptFile to be set.
    private string? cachedInlineContent;
    private string? cachedPromptFile;

    // Signaling editor ref (for coordinated save)
    private SignalingToolsEditor? signalingEditor;

    // Parameter form
    private bool showAddParameterForm = false;
    private string newParamName = "";
    private string newParamType = "string";
    private string newParamDescription = "";
    private bool newParamRequired = false;
    private string paramError = "";

    // Agent config
    private bool showAddToolSourceForm = false;
    private string selectedToolSourceToAdd = "";

    private static readonly System.Text.RegularExpressions.Regex PlaceholderRegex =
        new(@"\{\{(?:#(?:if|each)\s+)?([A-Za-z_][A-Za-z_0-9]*)\}\}",
            System.Text.RegularExpressions.RegexOptions.Compiled);

    protected override async Task OnParametersSetAsync()
    {
        EnsureToolInitialized();
        availablePromptFiles = ConfigService.ListPromptFiles().ToList();
        EnsureReferenceIdParameter();
        SyncSystemPromptMode();
        await LoadPromptContentAsync();
        await LoadSystemPromptFileContentAsync();
    }

    private async Task SetActiveTabAsync(string tab)
    {
        activeTab = tab;
        if (tab == "signaling")
        {
            availablePromptFiles = ConfigService.ListPromptFiles().ToList();
        }
        if (tab == "agent")
        {
            if (!modelsLoaded)
            {
                modelsLoaded = true;
                isLoadingModels = true;
                StateHasChanged();
                try
                {
                    var models = await AgentProvider.GetAvailableModelsAsync(CancellationToken.None);
                    availableModels = models.ToList();
                }
                catch
                {
                    availableModels = new List<string>();
                }
                finally
                {
                    isLoadingModels = false;
                }
            }
            await LoadCapabilitiesAsync(Tool.Agent?.Model);
        }
    }

    private async Task OnModelChangedAsync(ChangeEventArgs e)
    {
        var model = e.Value?.ToString() ?? string.Empty;
        Tool.Agent!.Model = model;
        await LoadCapabilitiesAsync(model);
    }

    private async Task LoadCapabilitiesAsync(string? model)
    {
        if (string.IsNullOrWhiteSpace(model))
        {
            selectedCapabilities = null;
            loadedCapabilitiesFor = null;
            return;
        }

        if (loadedCapabilitiesFor == model)
            return;

        isLoadingCapabilities = true;
        StateHasChanged();
        try
        {
            selectedCapabilities = await AgentProvider.GetModelCapabilitiesAsync(model, CancellationToken.None);
            loadedCapabilitiesFor = model;
            if (selectedCapabilities != null
                && !string.IsNullOrEmpty(Tool.Agent?.ReasoningEffort)
                && (!selectedCapabilities.SupportsReasoningEffort
                    || !selectedCapabilities.SupportedReasoningLevels.Contains(Tool.Agent.ReasoningEffort!, StringComparer.OrdinalIgnoreCase)))
            {
                Tool.Agent.ReasoningEffort = string.Empty;
            }
        }
        catch
        {
            selectedCapabilities = null;
        }
        finally
        {
            isLoadingCapabilities = false;
        }
    }

    private void EnsureToolInitialized()
    {
        if (Tool == null) return;

        Tool.Parameters ??= new Dictionary<string, ParameterDefinition>();
        Tool.Agent ??= new AgentConfiguration();
        Tool.Agent.Provider ??= "github-copilot"; // Default to the only integrated provider
        Tool.Agent.Tools ??= new List<string>();
        Tool.Session ??= new SessionConfiguration();
        Tool.Signaling ??= new SignalingConfiguration();
        Tool.Signaling.Tools ??= new List<SignalingToolEntry>();
    }

    // ==================== SYSTEM PROMPT EDITOR ====================

    private async Task LoadPromptContentAsync()
    {
        var file = Tool?.Agent?.PromptFile;
        if (string.IsNullOrWhiteSpace(file))
        {
            promptContent = string.Empty;
            loadedPromptFile = null;
            promptDirty = false;
            return;
        }

        if (loadedPromptFile == file && !promptDirty) return;

        try
        {
            promptContent = await ConfigService.GetPromptContentAsync(file);
            loadedPromptFile = file;
            promptDirty = false;
        }
        catch
        {
            promptContent = string.Empty;
            loadedPromptFile = file;
            promptDirty = false;
        }
    }

    private async Task OnPromptFilePathChangedAsync(ChangeEventArgs e)
    {
        var newPath = (e.Value?.ToString() ?? string.Empty).Trim();
        Tool!.Agent!.PromptFile = string.IsNullOrEmpty(newPath) ? null : newPath;
        await LoadPromptContentAsync();
    }

    private void OnPromptContentChanged(ChangeEventArgs e)
    {
        promptContent = e.Value?.ToString() ?? string.Empty;
        promptDirty = true;
    }

    // ==================== TOOL-LEVEL SYSTEM PROMPT EDITOR ====================

    private void SyncSystemPromptMode()
    {
        var sp = Tool?.SystemPrompt;
        if (sp == null)
        {
            SystemPromptMode = "default";
        }
        else if (!string.IsNullOrWhiteSpace(sp.PromptFile))
        {
            SystemPromptMode = "file";
        }
        else
        {
            // Treat a non-null SystemPrompt without PromptFile as inline, even if Content is empty —
            // the user explicitly opted into overriding the default.
            SystemPromptMode = "inline";
        }

        // Prime the round-trip caches from the loaded model so toggling preserves values.
        cachedInlineContent = sp?.Content;
        cachedPromptFile = sp?.PromptFile;
    }

    private async Task OnSystemPromptModeChangedAsync(ChangeEventArgs e)
    {
        var mode = e.Value?.ToString() ?? "default";
        SystemPromptMode = mode;

        // Capture whichever value the user last edited so it survives the toggle.
        if (Tool?.SystemPrompt != null)
        {
            if (!string.IsNullOrEmpty(Tool.SystemPrompt.Content))
                cachedInlineContent = Tool.SystemPrompt.Content;
            if (!string.IsNullOrWhiteSpace(Tool.SystemPrompt.PromptFile))
                cachedPromptFile = Tool.SystemPrompt.PromptFile;
        }

        switch (mode)
        {
            case "default":
                // Caches are retained so a later switch back into inline/file restores them.
                Tool!.SystemPrompt = null;
                systemPromptFileContent = string.Empty;
                loadedSystemPromptFile = null;
                systemPromptFileDirty = false;
                break;
            case "inline":
                Tool!.SystemPrompt = new SystemPromptConfiguration
                {
                    Content = cachedInlineContent ?? string.Empty,
                    PromptFile = null,
                };
                systemPromptFileContent = string.Empty;
                loadedSystemPromptFile = null;
                systemPromptFileDirty = false;
                break;
            case "file":
                Tool!.SystemPrompt = new SystemPromptConfiguration
                {
                    Content = null,
                    PromptFile = cachedPromptFile,
                };
                await LoadSystemPromptFileContentAsync();
                break;
        }
    }

    private void OnSystemPromptContentChanged(ChangeEventArgs e)
    {
        Tool!.SystemPrompt ??= new SystemPromptConfiguration();
        var value = e.Value?.ToString() ?? string.Empty;
        Tool.SystemPrompt.Content = value;
        Tool.SystemPrompt.PromptFile = null;
        cachedInlineContent = value;
    }

    private async Task OnSystemPromptFileChangedAsync(ChangeEventArgs e)
    {
        var newPath = (e.Value?.ToString() ?? string.Empty).Trim();
        Tool!.SystemPrompt ??= new SystemPromptConfiguration();
        Tool.SystemPrompt.PromptFile = string.IsNullOrEmpty(newPath) ? null : newPath;
        Tool.SystemPrompt.Content = null;
        cachedPromptFile = Tool.SystemPrompt.PromptFile;
        await LoadSystemPromptFileContentAsync();
    }

    private void OnSystemPromptFileContentChanged(ChangeEventArgs e)
    {
        systemPromptFileContent = e.Value?.ToString() ?? string.Empty;
        systemPromptFileDirty = true;
    }

    private async Task LoadSystemPromptFileContentAsync()
    {
        var file = Tool?.SystemPrompt?.PromptFile;
        if (string.IsNullOrWhiteSpace(file))
        {
            systemPromptFileContent = string.Empty;
            loadedSystemPromptFile = null;
            systemPromptFileDirty = false;
            return;
        }

        if (loadedSystemPromptFile == file && !systemPromptFileDirty) return;

        try
        {
            systemPromptFileContent = await ConfigService.GetPromptContentAsync(file);
            loadedSystemPromptFile = file;
            systemPromptFileDirty = false;
        }
        catch
        {
            systemPromptFileContent = string.Empty;
            loadedSystemPromptFile = file;
            systemPromptFileDirty = false;
        }
    }

    private string DefaultSystemPromptFilename() =>
        SanitizeSegment(string.IsNullOrWhiteSpace(ToolName) ? "tool" : ToolName) + "-system-prompt.md";

    private bool SystemPromptFileExists()
    {
        var file = Tool?.SystemPrompt?.PromptFile;
        if (string.IsNullOrWhiteSpace(file)) return false;
        try
        {
            return ConfigService.PromptFileExists(file);
        }
        catch
        {
            return false;
        }
    }

    private async Task CreateSystemPromptFileAsync()
    {
        Tool!.SystemPrompt ??= new SystemPromptConfiguration();
        if (string.IsNullOrWhiteSpace(Tool.SystemPrompt.PromptFile))
        {
            Tool.SystemPrompt.PromptFile = DefaultSystemPromptFilename();
        }
        Tool.SystemPrompt.Content = null;

        try
        {
            // Seed new files with the starter content already visible in the textarea
            // so nothing the user has typed is lost.
            await ConfigService.SavePromptContentAsync(Tool.SystemPrompt.PromptFile, systemPromptFileContent ?? string.Empty);
            loadedSystemPromptFile = Tool.SystemPrompt.PromptFile;
            systemPromptFileDirty = false;
            availablePromptFiles = ConfigService.ListPromptFiles().ToList();
        }
        catch (Exception ex)
        {
            SaveStatus = $"Error: {ex.Message}";
        }
    }

    private string DefaultPromptFilename() =>
        SanitizeSegment(string.IsNullOrWhiteSpace(ToolName) ? "tool" : ToolName) + ".md";

    private static string SanitizeSegment(string input) =>
        System.Text.RegularExpressions.Regex.Replace(input, "[^a-zA-Z0-9_-]", "-").Trim('-').ToLowerInvariant();

    private List<string> AllPlaceholderSources()
    {
        var names = new List<string>();
        if (Tool?.Parameters != null)
            names.AddRange(Tool.Parameters.Keys);
        if (Tool?.FixedParameters != null)
            names.AddRange(Tool.FixedParameters.Keys.Where(k => !names.Contains(k)));
        return names.OrderBy(n => n, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private List<string> DetectedPlaceholders()
    {
        if (string.IsNullOrEmpty(promptContent)) return new List<string>();
        return PlaceholderRegex.Matches(promptContent)
            .Cast<System.Text.RegularExpressions.Match>()
            .Select(m => m.Groups[1].Value)
            .Distinct(StringComparer.Ordinal)
            .OrderBy(p => p, StringComparer.Ordinal)
            .ToList();
    }

    private bool IsKnownPlaceholder(string upperSnake)
    {
        var camel = FromPlaceholder(upperSnake);
        return AllPlaceholderSources().Any(n => string.Equals(n, camel, StringComparison.OrdinalIgnoreCase));
    }

    private List<string> FindUnknownPlaceholders() =>
        DetectedPlaceholders().Where(p => !IsKnownPlaceholder(p)).ToList();

    private void InsertPlaceholder(string paramName)
    {
        var token = "{{" + ToPlaceholder(paramName) + "}}";
        promptContent = (promptContent ?? string.Empty) + token;
        promptDirty = true;
    }

    private static string ToPlaceholder(string camelCase)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < camelCase.Length; i++)
        {
            var c = camelCase[i];
            if (char.IsUpper(c) && i > 0) sb.Append('_');
            sb.Append(char.ToUpperInvariant(c));
        }
        return sb.ToString();
    }

    private static string FromPlaceholder(string upperSnake)
    {
        if (string.IsNullOrEmpty(upperSnake)) return upperSnake;
        var parts = upperSnake.Split('_');
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < parts.Length; i++)
        {
            var part = parts[i];
            if (part.Length == 0) continue;
            if (i == 0) sb.Append(part.ToLowerInvariant());
            else
            {
                sb.Append(char.ToUpperInvariant(part[0]));
                if (part.Length > 1) sb.Append(part.Substring(1).ToLowerInvariant());
            }
        }
        return sb.ToString();
    }

    // ==================== REFERENCE ID PARAMETER MANAGEMENT ====================

    private bool IsReferenceIdParameter(string paramName)
    {
        return Tool?.Session?.Mode == SessionMode.PerReference
            && !string.IsNullOrEmpty(Tool.Session.ReferenceIdParameter)
            && Tool.Session.ReferenceIdParameter == paramName;
    }

    private void OnSessionModeChanged()
    {
        EnsureReferenceIdParameter();
    }

    private void OnReferenceIdParameterNameChanged(ChangeEventArgs e)
    {
        if (Tool?.Session == null) return;

        var oldName = Tool.Session.ReferenceIdParameter;
        var newName = e.Value?.ToString()?.Trim() ?? string.Empty;

        if (newName == oldName) return;

        if (!string.IsNullOrEmpty(oldName) && Tool.Parameters.TryGetValue(oldName, out var existing))
        {
            Tool.Parameters.Remove(oldName);
            if (!string.IsNullOrEmpty(newName))
                Tool.Parameters[newName] = existing;
        }

        Tool.Session.ReferenceIdParameter = newName;
        EnsureReferenceIdParameter();
    }

    private void EnsureReferenceIdParameter()
    {
        if (Tool?.Session?.Mode != SessionMode.PerReference) return;

        if (string.IsNullOrWhiteSpace(Tool.Session.ReferenceIdParameter))
            Tool.Session.ReferenceIdParameter = "referenceId";

        var paramName = Tool.Session.ReferenceIdParameter;
        if (!Tool.Parameters.ContainsKey(paramName))
        {
            Tool.Parameters[paramName] = new ParameterDefinition
            {
                Type = "string",
                Required = true,
                Description = "Tracks the conversation across multiple calls."
            };
        }
    }

    // ==================== PARAMETER METHODS ====================
    private void ShowAddParameter()
    {
        showAddParameterForm = true;
        newParamName = "";
        newParamType = "string";
        newParamDescription = "";
        newParamRequired = false;
        paramError = "";
    }

    private void CancelAddParameter()
    {
        showAddParameterForm = false;
        paramError = "";
    }

    private void AddParameter()
    {
        paramError = "";

        if (string.IsNullOrWhiteSpace(newParamName))
        {
            paramError = "Parameter name is required";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(newParamName, @"^[a-zA-Z][a-zA-Z0-9_]*$"))
        {
            paramError = "Parameter name must start with a letter and contain only letters, numbers, and underscores";
            return;
        }

        if (Tool?.Parameters?.ContainsKey(newParamName) == true)
        {
            paramError = $"A parameter named '{newParamName}' already exists";
            return;
        }

        if (IsReferenceIdParameter(newParamName))
        {
            paramError = $"'{newParamName}' is a managed parameter and cannot be added manually";
            return;
        }

        Tool!.Parameters![newParamName] = new ParameterDefinition
        {
            Type = newParamType,
            Description = newParamDescription,
            Required = newParamRequired
        };

        showAddParameterForm = false;
    }

    private void RemoveParameter(string paramName)
    {
        if (IsReferenceIdParameter(paramName)) return;
        Tool?.Parameters?.Remove(paramName);
    }

    // ==================== AGENT CONFIG METHODS ====================
    private void ShowAddToolSource()
    {
        showAddToolSourceForm = true;
        selectedToolSourceToAdd = "";
    }

    private void AddToolSource()
    {
        if (!string.IsNullOrEmpty(selectedToolSourceToAdd) && Tool?.Agent?.Tools != null)
        {
            if (!Tool.Agent.Tools.Contains(selectedToolSourceToAdd))
            {
                Tool.Agent.Tools.Add(selectedToolSourceToAdd);
            }
        }
        showAddToolSourceForm = false;
        selectedToolSourceToAdd = "";
    }

    private void RemoveToolSource(string toolSource)
    {
        Tool?.Agent?.Tools?.Remove(toolSource);
    }

    // ==================== SAVE/DELETE METHODS ====================
    private async Task SaveAsync()
    {
        try
        {
            // Persist the inline system prompt first.
            if (promptDirty || (!string.IsNullOrEmpty(Tool?.Agent?.PromptFile) && Tool.Agent.PromptFile != loadedPromptFile))
            {
                var file = Tool?.Agent?.PromptFile;
                if (string.IsNullOrWhiteSpace(file))
                {
                    file = DefaultPromptFilename();
                    Tool!.Agent!.PromptFile = file;
                }
                await ConfigService.SavePromptContentAsync(file, promptContent ?? string.Empty);
                loadedPromptFile = file;
                promptDirty = false;
            }

            // Persist the static system-prompt file when file-mode is active.
            if (SystemPromptMode == "file"
                && !string.IsNullOrWhiteSpace(Tool?.SystemPrompt?.PromptFile)
                && (systemPromptFileDirty || Tool.SystemPrompt.PromptFile != loadedSystemPromptFile))
            {
                var spFile = Tool.SystemPrompt.PromptFile!;
                await ConfigService.SavePromptContentAsync(spFile, systemPromptFileContent ?? string.Empty);
                loadedSystemPromptFile = spFile;
                systemPromptFileDirty = false;
            }

            // Persist any inline-edited signaling prompts.
            if (signalingEditor != null)
            {
                await signalingEditor.SavePendingPromptsAsync();
            }

            // Finally, save the JSON config.
            await OnSave.Invoke();

            availablePromptFiles = ConfigService.ListPromptFiles().ToList();
            SaveStatus = "Saved successfully";
            await Task.Delay(2000);
            SaveStatus = "";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            SaveStatus = $"Error: {ex.Message}";
        }
    }

    private void ConfirmDelete()
    {
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
    }

    private async Task DeleteAsync()
    {
        if (OnDelete != null)
        {
            await OnDelete.Invoke();
        }
        showDeleteConfirm = false;
    }


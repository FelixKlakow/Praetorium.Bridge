@using Praetorium.Bridge.Configuration
@using Praetorium.Bridge.Signaling
@using Praetorium.Bridge.Web.Services
@inject ConfigurationService ConfigService

<div class="section">
    <h3>Signaling Configuration</h3>
    <p class="section-description">Signaling tools let the agent send output to the client, request input, or wait for external signals during execution.</p>

    <div class="form-group">
        <label>Keepalive Interval (seconds):</label>
        <input type="number" @bind="Signaling.KeepaliveIntervalSeconds" class="form-input" min="5" max="300" />
        <p class="field-hint">How often the agent sends keepalive signals during long operations.</p>
    </div>

    <div class="form-group">
        <div class="section-header">
            <label>Signaling Tools:</label>
            <div class="add-signaling-actions">
                @if (ShowDefaultPresets)
                {
                    <select @bind="selectedDefaultToAdd" class="form-input inline">
                        <option value="">-- Add default signaling --</option>
                        @foreach (var def in availableDefaults)
                        {
                            <option value="@def">@def</option>
                        }
                    </select>
                    <button class="add-button small" @onclick="AddDefault" disabled="@(string.IsNullOrEmpty(selectedDefaultToAdd))">+ Add Default</button>
                }
                <button class="add-button small" @onclick="ShowAddCustom">+ Add Custom</button>
            </div>
        </div>

        @if (showAddCustomForm)
        {
            <div class="add-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>Signal Name:</label>
                        <input type="text" @bind="newCustomName" class="form-input" placeholder="e.g., request_approval" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Description:</label>
                    <input type="text" @bind="newCustomDescription" class="form-input" placeholder="Describe when the agent should use this signal..." />
                </div>
                @if (!string.IsNullOrEmpty(customError))
                {
                    <div class="status-message error">@customError</div>
                }
                <div class="form-actions">
                    <button class="cancel-button" @onclick="CancelAddCustom">Cancel</button>
                    <button class="save-button" @onclick="AddCustom">Add</button>
                </div>
            </div>
        }

        @if (Signaling.Tools.Count == 0)
        {
            <p class="empty-state small">No signaling tools configured.</p>
        }
        else
        {
            <div class="signaling-list">
                @for (var i = 0; i < Signaling.Tools.Count; i++)
                {
                    var entry = Signaling.Tools[i];
                    var index = i;
                    var isBuiltIn = IsBuiltInName(entry.Name);
                    var expanded = expandedIndex == index;
                    var supportsOutgoing = !IsAwaitSignal(entry.Name);
                    <div class="signaling-entry">
                        <div class="entry-header">
                            <button class="expand-toggle" @onclick="() => ToggleExpand(index)" title="@(expanded ? "Collapse" : "Expand")">
                                @(expanded ? "▾" : "▸")
                            </button>
                            <span class="signal-name">@entry.Name</span>
                            @if (isBuiltIn)
                            {
                                <span class="signal-badge builtin">built-in</span>
                            }
                            else
                            {
                                <span class="signal-badge custom">custom</span>
                            }
                            @if (entry.IsBlocking)
                            {
                                <span class="signal-badge blocking">blocking</span>
                            }
                            <span class="signal-description">@entry.Description</span>
                            <button class="remove-button" @onclick="() => RemoveEntry(index)" title="Remove signaling tool">×</button>
                        </div>

                        @if (expanded)
                        {
                            <div class="entry-body">
                                <div class="form-group">
                                    <label>Name:</label>
                                    <input type="text" @bind="entry.Name" class="form-input" />
                                </div>

                                <div class="form-group">
                                    <label>Description:</label>
                                    <input type="text" @bind="entry.Description" class="form-input" />
                                </div>

                                <ParameterListEditor Parameters="entry.Parameters" Title="Request Parameters"
                                                     EmptyText="No request parameters. The agent invokes this signal without arguments." />

                                @if (supportsOutgoing)
                                {
                                    <div class="signal-direction">
                                        <div class="direction-label">→ Outgoing (to external caller)</div>

                                        <div class="form-group">
                                            <label>Outgoing Format:</label>
                                            <select value="@(entry.OutgoingFormat ?? SignalingToolFactory.JsonResponseFormat)"
                                                    @onchange="(e) => OnOutgoingFormatChanged(entry, e.Value?.ToString())"
                                                    class="form-input">
                                                <option value="@SignalingToolFactory.JsonResponseFormat">JSON (structured payload)</option>
                                                <option value="@SignalingToolFactory.MarkdownResponseFormat">Markdown (template file)</option>
                                            </select>
                                            <p class="field-hint">Format of the data delivered to the external caller when the agent invokes this signal.</p>
                                        </div>

                                        @if (IsMarkdown(entry.OutgoingFormat))
                                        {
                                            <div class="form-group">
                                                <label>Outgoing Prompt File:</label>
                                                <input type="text" value="@entry.OutgoingPromptFile"
                                                       @onchange="(e) => OnPromptFilePathChanged(entry, PromptSlot.Outgoing, e.Value?.ToString())"
                                                       class="form-input" />
                                            </div>
                                            <div class="form-group">
                                                <label>Template:</label>
                                                <textarea class="form-textarea prompt-inline-editor" rows="8"
                                                          value="@GetLoadedContent(entry.OutgoingPromptFile)"
                                                          @onchange="(e) => OnPromptContentChanged(entry.OutgoingPromptFile, e.Value?.ToString())"></textarea>
                                                @{
                                                    var unknownOut = FindUnknownPlaceholders(entry, entry.OutgoingPromptFile);
                                                }
                                                @if (unknownOut.Count > 0)
                                                {
                                                    <div class="placeholder-warn">
                                                        Unknown placeholder@(unknownOut.Count == 1 ? "" : "s"):
                                                        @string.Join(", ", unknownOut.Select(p => $"{{{{{p}}}}}"))
                                                    </div>
                                                }
                                                <p class="field-hint">
                                                    Rendered with the agent's signal parameters. Available placeholders: @FormatPlaceholderHints(entry)
                                                </p>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="form-group">
                                    <label class="checkbox-label">
                                        <input type="checkbox" checked="@entry.IsBlocking"
                                               @onchange="(e) => OnBlockingChanged(entry, (bool)(e.Value ?? false))" />
                                        <span class="checkbox-text">
                                            <strong>Blocking</strong> — agent waits for a response from the client before continuing
                                        </span>
                                    </label>
                                </div>

                                @if (entry.IsBlocking)
                                {
                                    <div class="form-group">
                                        <label class="checkbox-label">
                                            <input type="checkbox" checked="@entry.AcceptsNewPrompt"
                                                   @onchange="(e) => OnAcceptsNewPromptChanged(entry, (bool)(e.Value ?? false))" />
                                            <span class="checkbox-text">
                                                <strong>Accepts new prompt</strong> — while parked here, the agent is open to a brand-new prompt from the caller (use for terminal/respond-style tools; leave off for tools that demand a specific reply such as <code>request_input</code>)
                                            </span>
                                        </label>
                                    </div>

                                    <div class="signal-direction">
                                        <div class="direction-label">← Response (from external caller back to agent)</div>

                                        <div class="form-group">
                                            <label>Response Format:</label>
                                            <select value="@(entry.ResponseFormat ?? SignalingToolFactory.JsonResponseFormat)"
                                                    @onchange="(e) => OnResponseFormatChanged(entry, e.Value?.ToString())"
                                                    class="form-input">
                                                <option value="@SignalingToolFactory.JsonResponseFormat">JSON (structured response)</option>
                                                <option value="@SignalingToolFactory.MarkdownResponseFormat">Markdown (prompt template)</option>
                                            </select>
                                        </div>

                                        @if (IsMarkdown(entry.ResponseFormat))
                                        {
                                            <div class="form-group">
                                                <label>Response Prompt File:</label>
                                                <input type="text" value="@entry.ResponsePromptFile"
                                                       @onchange="(e) => OnPromptFilePathChanged(entry, PromptSlot.Response, e.Value?.ToString())"
                                                       class="form-input" />
                                            </div>
                                            <div class="form-group">
                                                <label>Template:</label>
                                                <textarea class="form-textarea prompt-inline-editor" rows="8"
                                                          value="@GetLoadedContent(entry.ResponsePromptFile)"
                                                          @onchange="(e) => OnPromptContentChanged(entry.ResponsePromptFile, e.Value?.ToString())"></textarea>
                                                <p class="field-hint">Contents are returned verbatim to the agent as the blocking response.</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <ParameterListEditor Parameters="GetOrCreateResponseParameters(entry)"
                                                                 Title="Response Parameters"
                                                                 EmptyText="No response parameters. The response schema is an empty object." />
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public required SignalingConfiguration Signaling { get; set; }

    [Parameter]
    public IReadOnlyList<string> AvailablePromptFiles { get; set; } = Array.Empty<string>();

    [Parameter]
    public string ToolName { get; set; } = string.Empty;

    /// <summary>
    /// When false, hides the built-in preset dropdown ("respond", "request_input", "await_signal")
    /// and its "+ Add Default" button. Set to false from the Defaults page, where these presets
    /// would be redundant (the list itself IS the defaults).
    /// </summary>
    [Parameter]
    public bool ShowDefaultPresets { get; set; } = true;

    private enum PromptSlot { Outgoing, Response }

    private readonly string[] availableDefaults = new[]
    {
        SignalingToolFactory.RespondToolName,
        SignalingToolFactory.RequestInputToolName,
        SignalingToolFactory.AwaitSignalToolName,
    };

    // Loaded markdown content for inline editing. Key is the (normalized) file name.
    private readonly Dictionary<string, string> loadedContent = new(StringComparer.OrdinalIgnoreCase);
    // Files that have been edited since last save.
    private readonly HashSet<string> dirtyFiles = new(StringComparer.OrdinalIgnoreCase);

    private int expandedIndex = -1;
    private string selectedDefaultToAdd = string.Empty;
    private bool showAddCustomForm;
    private string newCustomName = string.Empty;
    private string newCustomDescription = string.Empty;
    private string customError = string.Empty;

    protected override void OnParametersSet()
    {
        Signaling.Tools ??= new List<SignalingToolEntry>();
    }

    /// <summary>
    /// Persists any edited outgoing/response prompt files to disk. Called by the parent
    /// editor before it saves the tool's JSON configuration.
    /// </summary>
    public async Task SavePendingPromptsAsync(CancellationToken ct = default)
    {
        if (dirtyFiles.Count == 0) return;

        foreach (var file in dirtyFiles.ToList())
        {
            if (!loadedContent.TryGetValue(file, out var content))
                continue;
            await ConfigService.SavePromptContentAsync(file, content, ct);
        }
        dirtyFiles.Clear();
    }

    private static bool IsBuiltInName(string name) =>
        name is SignalingToolFactory.RespondToolName
             or SignalingToolFactory.RequestInputToolName
             or SignalingToolFactory.AwaitSignalToolName;

    private static bool IsAwaitSignal(string name) =>
        name == SignalingToolFactory.AwaitSignalToolName;

    private static bool IsMarkdown(string? format) =>
        string.Equals(format, SignalingToolFactory.MarkdownResponseFormat, StringComparison.OrdinalIgnoreCase);

    private void ToggleExpand(int index)
    {
        expandedIndex = expandedIndex == index ? -1 : index;
    }

    private void AddDefault()
    {
        if (string.IsNullOrEmpty(selectedDefaultToAdd))
            return;
        if (Signaling.Tools.Any(t => t.Name == selectedDefaultToAdd))
        {
            selectedDefaultToAdd = string.Empty;
            return;
        }

        Signaling.Tools.Add(CreateDefaultEntry(selectedDefaultToAdd));
        expandedIndex = Signaling.Tools.Count - 1;
        selectedDefaultToAdd = string.Empty;
    }

    private static SignalingToolEntry CreateDefaultEntry(string name) => name switch
    {
        SignalingToolFactory.RespondToolName => new SignalingToolEntry
        {
            Name = name,
            Description = "Send a response message back to the client during execution.",
            Parameters = new Dictionary<string, ParameterDefinition>
            {
                ["message"] = new ParameterDefinition
                {
                    Type = "string",
                    Description = "The message to send back to the client.",
                    Required = true,
                },
                ["metadata"] = new ParameterDefinition
                {
                    Type = "object",
                    Description = "Optional structured metadata to include with the response.",
                },
            },
            IsBlocking = false,
            OutgoingFormat = SignalingToolFactory.JsonResponseFormat,
        },
        SignalingToolFactory.RequestInputToolName => new SignalingToolEntry
        {
            Name = name,
            Description = "Ask the user a question and wait for their answer.",
            Parameters = new Dictionary<string, ParameterDefinition>
            {
                ["question"] = new ParameterDefinition
                {
                    Type = "string",
                    Description = "The question to ask the user.",
                    Required = true,
                },
                ["options"] = new ParameterDefinition
                {
                    Type = "array",
                    Description = "Optional list of choices to offer the user.",
                    Items = new ParameterDefinition { Type = "string" },
                },
            },
            IsBlocking = true,
            OutgoingFormat = SignalingToolFactory.JsonResponseFormat,
            ResponseFormat = SignalingToolFactory.JsonResponseFormat,
            ResponseParameters = new Dictionary<string, ParameterDefinition>
            {
                ["answer"] = new ParameterDefinition
                {
                    Type = "string",
                    Description = "The user's answer.",
                    Required = true,
                },
            },
        },
        SignalingToolFactory.AwaitSignalToolName => new SignalingToolEntry
        {
            Name = name,
            Description = "Wait for the next signal from the client without sending a message.",
            Parameters = new Dictionary<string, ParameterDefinition>(),
            IsBlocking = true,
            ResponseFormat = SignalingToolFactory.JsonResponseFormat,
            ResponseParameters = new Dictionary<string, ParameterDefinition>(),
        },
        _ => new SignalingToolEntry { Name = name },
    };

    private void ShowAddCustom()
    {
        showAddCustomForm = true;
        newCustomName = string.Empty;
        newCustomDescription = string.Empty;
        customError = string.Empty;
    }

    private void CancelAddCustom()
    {
        showAddCustomForm = false;
        customError = string.Empty;
    }

    private void AddCustom()
    {
        customError = string.Empty;

        if (string.IsNullOrWhiteSpace(newCustomName))
        {
            customError = "Signal name is required.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(newCustomName, @"^[a-zA-Z][a-zA-Z0-9_]*$"))
        {
            customError = "Signal name must start with a letter and contain only letters, digits, and underscores.";
            return;
        }

        if (Signaling.Tools.Any(t => t.Name == newCustomName))
        {
            customError = $"A signaling tool named '{newCustomName}' already exists.";
            return;
        }

        Signaling.Tools.Add(new SignalingToolEntry
        {
            Name = newCustomName,
            Description = newCustomDescription,
            Parameters = new Dictionary<string, ParameterDefinition>(),
            IsBlocking = false,
            OutgoingFormat = SignalingToolFactory.JsonResponseFormat,
        });

        expandedIndex = Signaling.Tools.Count - 1;
        showAddCustomForm = false;
    }

    private void RemoveEntry(int index)
    {
        if (index < 0 || index >= Signaling.Tools.Count)
            return;
        Signaling.Tools.RemoveAt(index);
        if (expandedIndex == index)
            expandedIndex = -1;
        else if (expandedIndex > index)
            expandedIndex--;
    }

    private void OnBlockingChanged(SignalingToolEntry entry, bool value)
    {
        entry.IsBlocking = value;
        if (!value)
        {
            entry.ResponseFormat = null;
            entry.ResponseParameters = null;
            entry.ResponsePromptFile = null;
            // acceptsNewPrompt is only valid for blocking tools; clear it so
            // configurations stay consistent with the runtime validation.
            entry.AcceptsNewPrompt = false;
        }
        else
        {
            entry.ResponseFormat ??= SignalingToolFactory.JsonResponseFormat;
        }
    }

    private void OnAcceptsNewPromptChanged(SignalingToolEntry entry, bool value)
    {
        // Guarded in markup (only shown when IsBlocking) but defended here too.
        entry.AcceptsNewPrompt = value && entry.IsBlocking;
    }

    private async Task OnOutgoingFormatChanged(SignalingToolEntry entry, string? format)
    {
        entry.OutgoingFormat = format;
        if (IsMarkdown(format))
        {
            if (string.IsNullOrWhiteSpace(entry.OutgoingPromptFile))
                entry.OutgoingPromptFile = DefaultPromptFile(entry, PromptSlot.Outgoing);
            await EnsureLoadedAsync(entry.OutgoingPromptFile);
        }
    }

    private async Task OnResponseFormatChanged(SignalingToolEntry entry, string? format)
    {
        entry.ResponseFormat = format;
        if (IsMarkdown(format))
        {
            entry.ResponseParameters = null;
            if (string.IsNullOrWhiteSpace(entry.ResponsePromptFile))
                entry.ResponsePromptFile = DefaultPromptFile(entry, PromptSlot.Response);
            await EnsureLoadedAsync(entry.ResponsePromptFile);
        }
        else
        {
            entry.ResponsePromptFile = null;
            entry.ResponseParameters ??= new Dictionary<string, ParameterDefinition>();
        }
    }

    private async Task OnPromptFilePathChanged(SignalingToolEntry entry, PromptSlot slot, string? newPath)
    {
        var trimmed = (newPath ?? string.Empty).Trim();
        if (slot == PromptSlot.Outgoing)
            entry.OutgoingPromptFile = trimmed;
        else
            entry.ResponsePromptFile = trimmed;

        if (!string.IsNullOrEmpty(trimmed))
            await EnsureLoadedAsync(trimmed);
    }

    private void OnPromptContentChanged(string? file, string? content)
    {
        if (string.IsNullOrWhiteSpace(file)) return;
        var key = NormalizeFile(file);
        loadedContent[key] = content ?? string.Empty;
        dirtyFiles.Add(key);
    }

    private string GetLoadedContent(string? file)
    {
        if (string.IsNullOrWhiteSpace(file)) return string.Empty;
        return loadedContent.TryGetValue(NormalizeFile(file), out var c) ? c : string.Empty;
    }

    private async Task EnsureLoadedAsync(string? file)
    {
        if (string.IsNullOrWhiteSpace(file)) return;
        var key = NormalizeFile(file);
        if (loadedContent.ContainsKey(key)) return;

        try
        {
            var content = await ConfigService.GetPromptContentAsync(key);
            loadedContent[key] = content;
        }
        catch
        {
            loadedContent[key] = string.Empty;
        }
    }

    private string DefaultPromptFile(SignalingToolEntry entry, PromptSlot slot)
    {
        var tool = SanitizeSegment(string.IsNullOrWhiteSpace(ToolName) ? "tool" : ToolName);
        var signal = SanitizeSegment(string.IsNullOrWhiteSpace(entry.Name) ? "signal" : entry.Name);
        var suffix = slot == PromptSlot.Outgoing ? "outgoing" : "response";
        return $"{tool}-{signal}-{suffix}.md";
    }

    private static string SanitizeSegment(string input) =>
        System.Text.RegularExpressions.Regex.Replace(input, "[^a-zA-Z0-9_-]", "-").Trim('-').ToLowerInvariant();

    private static string NormalizeFile(string file)
    {
        var normalized = file.Replace('\\', '/').TrimStart('/');
        if (normalized.StartsWith("./", StringComparison.Ordinal))
            normalized = normalized.Substring(2);
        if (normalized.StartsWith("prompts/", StringComparison.OrdinalIgnoreCase))
            normalized = normalized.Substring("prompts/".Length);
        return normalized;
    }

    private List<string> FindUnknownPlaceholders(SignalingToolEntry entry, string? file)
    {
        var content = GetLoadedContent(file);
        if (string.IsNullOrEmpty(content)) return new List<string>();

        var knownUpper = entry.Parameters.Keys
            .Select(ToPlaceholder)
            .ToHashSet(StringComparer.Ordinal);

        var pattern = new System.Text.RegularExpressions.Regex(
            @"\{\{(?:#(?:if|each)\s+)?([A-Z_][A-Z_0-9]*)\}\}",
            System.Text.RegularExpressions.RegexOptions.Compiled);

        return pattern.Matches(content)
            .Cast<System.Text.RegularExpressions.Match>()
            .Select(m => m.Groups[1].Value)
            .Distinct(StringComparer.Ordinal)
            .Where(p => !knownUpper.Contains(p))
            .OrderBy(p => p, StringComparer.Ordinal)
            .ToList();
    }

    private static string ToPlaceholder(string camelCase)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < camelCase.Length; i++)
        {
            var c = camelCase[i];
            if (char.IsUpper(c) && i > 0) sb.Append('_');
            sb.Append(char.ToUpperInvariant(c));
        }
        return sb.ToString();
    }

    private static string FormatPlaceholderHints(SignalingToolEntry entry)
    {
        if (entry.Parameters.Count == 0) return "none";
        return string.Join(", ", entry.Parameters.Keys.Select(p => $"{{{{{ToPlaceholder(p)}}}}}"));
    }

    private Dictionary<string, ParameterDefinition> GetOrCreateResponseParameters(SignalingToolEntry entry)
    {
        entry.ResponseParameters ??= new Dictionary<string, ParameterDefinition>();
        return entry.ResponseParameters;
    }
}

@page "/sessions"
@rendermode InteractiveServer
@using System.Threading
@using Praetorium.Bridge.Agents
@using Praetorium.Bridge.Sessions
@using Praetorium.Bridge.Web.Services
@inject SessionActivityService Activity
@inject ILogger<SessionView> Logger
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Sessions - Praetorium.Bridge</PageTitle>

<div class="session-view-page">
    <div class="session-header">
        <div>
            <h1>Sessions</h1>
            <p class="subtitle">Watch live bridge activity, signaling, and agent internals per session. Use Cancel to release a session that is parked inside a blocking signaling tool.</p>
        </div>
        <div class="session-controls">
            <label class="filter-label">
                <input type="checkbox" @bind="autoFollow" /> Auto-scroll
            </label>
            <button class="save-button" @onclick="RefreshSessionsAsync" disabled="@isLoading">Refresh</button>
        </div>
    </div>

    <div class="session-body">
        <aside class="session-list">
            <div class="session-list-header">
                <h2>Active / known</h2>
                <span class="badge">@sessions.Count</span>
            </div>
            @if (sessions.Count == 0)
            {
                <div class="empty-state small">No sessions yet — trigger a bridge tool to spawn one.</div>
            }
            else
            {
                <ul class="session-items">
                    @foreach (var s in sessions)
                    {
                        <li class="@(s.SessionId == selectedSessionId ? "session-item selected" : "session-item")"
                            @onclick="() => SelectSession(s.SessionId)">
                            <div class="session-item-head">
                                <span class="session-tool">@s.ToolName</span>
                                <span class="session-state @StateClass(s.State)">@s.State</span>
                            </div>
                            <div class="session-item-id">@s.SessionId</div>
                            <div class="session-item-meta">
                                @if (!string.IsNullOrEmpty(s.ReferenceId))
                                {
                                    <span>ref: @s.ReferenceId</span>
                                }
                                <span>· @s.ToolCallCount calls</span>
                            </div>
                        </li>
                    }
                </ul>
            }
        </aside>

        <section class="transcript-panel">
            <div class="transcript-header">
                <div class="transcript-title">
                    @if (string.IsNullOrEmpty(selectedSessionId))
                    {
                        <h2>Select a session</h2>
                    }
                    else
                    {
                        <h2>@selectedSessionId</h2>
                        <div class="transcript-sub">@transcript.Count entries</div>
                    }
                </div>
                <div class="transcript-actions">
                    <button class="cancel-button" @onclick="CancelWaitsAsync"
                            disabled="@(string.IsNullOrEmpty(selectedSessionId) || isCancelling)"
                            title="Release any blocking signaling waits on this session (Reset on both channels)">
                        @(isCancelling ? "Cancelling…" : "Cancel waits")
                    </button>
                    <button class="cancel-button" @onclick="ClearTranscript"
                            disabled="@(string.IsNullOrEmpty(selectedSessionId))">
                        Clear view
                    </button>
                    <button class="save-button" @onclick="SaveTranscriptAsync"
                            disabled="@(string.IsNullOrEmpty(selectedSessionId) || transcript.Count == 0 || isSaving)"
                            title="Download the current session transcript as a JSON file for offline investigation">
                        @(isSaving ? "Saving…" : "Save log")
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(lastError))
            {
                <div class="status-message error inline">@lastError</div>
            }

            <div class="transcript-chat-wrapper">
                @if (string.IsNullOrEmpty(selectedSessionId))
                {
                    <div class="empty-state small">Pick a session on the left to see its live transcript.</div>
                }
                else if (transcript.Count == 0)
                {
                    <div class="empty-state small">No activity yet — events stream here as the session runs.</div>
                }
                else
                {
                    <AgentChatView Messages="chatMessages"
                                   ToolContentTemplate="SignalingToolTemplate"
                                   Options="@(new AgentChatOptions
                                   {
                                       AutoScroll = autoFollow,
                                       ShowTimestamps = true,
                                       EnableMarkdown = true,
                                       ToolCallDisplay = ToolCallDisplayMode.CollapsibleExpanded,
                                   })" />
                }
            </div>
        </section>
    </div>
</div>

@code {
    private List<SessionInfo> sessions = new();
    private List<SessionTranscriptEntry> transcript = new();
    private List<ChatMessage> chatMessages = new();
    private readonly Dictionary<string, List<SignalingStep>> _signalingRenderData = new();
    private RenderFragment<ToolCall>? _signalingToolTemplate;
    private string? selectedSessionId;
    private bool autoFollow = true;
    private bool isLoading;
    private bool isCancelling;
    private bool isSaving;
    private string? lastError;
    private CancellationTokenSource? cts;
    private readonly HashSet<string> clearedLocally = new(StringComparer.Ordinal);

    private RenderFragment<ToolCall> SignalingToolTemplate =>
        _signalingToolTemplate ??= tool =>
        {
            if (!_signalingRenderData.TryGetValue(tool.Id, out var steps)) return null!;
            return __builder => RenderSignalingSteps(__builder, steps);
        };

    protected override async Task OnInitializedAsync()
    {
        cts = new CancellationTokenSource();
        Activity.EntryAdded += OnEntryAdded;
        Activity.SessionsChanged += OnSessionsChanged;
        await RefreshSessionsAsync();
    }

    private async Task RefreshSessionsAsync()
    {
        if (isLoading) return;
        isLoading = true;
        lastError = null;
        try
        {
            var all = await Activity.GetSessionsAsync(cts?.Token ?? CancellationToken.None);
            sessions = all.OrderByDescending(s => s.LastActivityAt).ToList();

            if (selectedSessionId is null && sessions.Count > 0)
            {
                SelectSession(sessions[0].SessionId);
            }
        }
        catch (Exception ex)
        {
            lastError = ex.Message;
            Logger.LogError(ex, "Refresh sessions failed.");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SelectSession(string sessionId)
    {
        selectedSessionId = sessionId;
        transcript = Activity.GetTranscript(sessionId).ToList();
        clearedLocally.Remove(sessionId);
        RebuildChatMessages();
        StateHasChanged();
    }

    private void ClearTranscript()
    {
        if (string.IsNullOrEmpty(selectedSessionId)) return;
        transcript = new List<SessionTranscriptEntry>();
        chatMessages = new List<ChatMessage>();
        _signalingRenderData.Clear();
        clearedLocally.Add(selectedSessionId);
        StateHasChanged();
    }

    private async Task CancelWaitsAsync()
    {
        if (string.IsNullOrEmpty(selectedSessionId) || isCancelling) return;
        isCancelling = true;
        lastError = null;
        try
        {
            var ok = await Activity.CancelWaitsAsync(selectedSessionId!, cts?.Token ?? CancellationToken.None);
            if (!ok)
            {
                lastError = "Session not found or already torn down.";
            }
        }
        catch (Exception ex)
        {
            lastError = ex.Message;
            Logger.LogError(ex, "Cancel waits failed.");
        }
        finally
        {
            isCancelling = false;
            StateHasChanged();
        }
    }

    private async Task SaveTranscriptAsync()
    {
        if (string.IsNullOrEmpty(selectedSessionId) || transcript.Count == 0 || isSaving) return;
        isSaving = true;
        lastError = null;
        try
        {
            var payload = new
            {
                sessionId = selectedSessionId,
                exportedAt = DateTimeOffset.UtcNow,
                entryCount = transcript.Count,
                entries = transcript,
            };
            var json = System.Text.Json.JsonSerializer.Serialize(payload, TranscriptExportOptions);
            var filename = $"session-{selectedSessionId}-{DateTimeOffset.UtcNow:yyyyMMdd-HHmmss}.json";
            await JS.InvokeVoidAsync("praetoriumDownload", filename, json, "application/json");
        }
        catch (Exception ex)
        {
            lastError = ex.Message;
            Logger.LogError(ex, "Save transcript failed.");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void OnEntryAdded(SessionTranscriptEntry entry)
    {
        if (entry.SessionId != selectedSessionId) return;
        if (clearedLocally.Contains(entry.SessionId)) return;

        InvokeAsync(() =>
        {
            transcript.Add(entry);
            RebuildChatMessages();
            StateHasChanged();
        });
    }

    private void OnSessionsChanged()
    {
        InvokeAsync(async () =>
        {
            await RefreshSessionsAsync();
        });
    }

    private void RebuildChatMessages()
    {
        chatMessages = BuildChatMessages(transcript);
    }

    private List<ChatMessage> BuildChatMessages(IReadOnlyList<SessionTranscriptEntry> entries)
    {
        _signalingRenderData.Clear();
        var result = new List<ChatMessage>();
        var toolPairs = BuildToolPairs(entries);

        List<ToolCall>? pendingTools = null;
        DateTimeOffset pendingStart = default;

        void FlushPendingTools()
        {
            if (pendingTools == null) return;
            result.Add(new ChatMessage
            {
                Role = MessageRole.Assistant,
                Timestamp = pendingStart,
                RoleLabel = "",
                ShowTimestamp = false,
                ToolCalls = pendingTools,
            });
            pendingTools = null;
        }

        for (int i = 0; i < entries.Count; i++)
        {
            if (toolPairs.SkipIndices.Contains(i)) continue;

            var entry = entries[i];
            bool isToolStart = entry.Source == SessionTranscriptSource.Agent
                && entry.Kind == nameof(AgentActivityKind.ToolStart);

            if (isToolStart && IsThoughtTool(entry.Title))
            {
                FlushPendingTools();
                var thoughtText = ExtractThoughtText(entry.Details) ?? entry.Details;
                if (!string.IsNullOrWhiteSpace(thoughtText))
                {
                    var capturedText = thoughtText;
                    result.Add(new ChatMessage
                    {
                        Role = MessageRole.Assistant,
                        Timestamp = entry.Timestamp,
                        RoleLabel = "",
                        ShowTimestamp = false,
                        CustomContent = b =>
                        {
                            b.OpenElement(0, "div");
                            b.AddAttribute(1, "class", "pbt-thought");
                            b.AddContent(2, capturedText);
                            b.CloseElement();
                        },
                    });
                }
                continue;
            }

            if (isToolStart)
            {
                SessionTranscriptEntry? completeEntry = toolPairs.StartToComplete.TryGetValue(i, out var ci)
                    ? entries[ci] : null;
                toolPairs.StartToSignals.TryGetValue(i, out var signalIndices);

                bool isError = completeEntry?.Details?.Contains("success=False", StringComparison.Ordinal) == true;
                ToolState state = completeEntry == null ? ToolState.Running
                    : isError ? ToolState.Failed
                    : ToolState.Success;

                var toolCallId = $"tc-{i}";
                var toolCall = new ToolCall
                {
                    Id = toolCallId,
                    ToolName = entry.Title ?? "tool",
                    Input = entry.Details,
                    Output = isError ? completeEntry?.Details : null,
                    State = state,
                };

                if (signalIndices != null && signalIndices.Count > 0)
                {
                    var steps = new List<SignalingStep>();
                    if (!string.IsNullOrEmpty(entry.Details))
                        steps.Add(new SignalingStep("params", "Parameters (agent → tool)", entry.Details, entry.Timestamp));

                    foreach (var sIdx in signalIndices)
                    {
                        var s = entries[sIdx];
                        var direction = SignalingDirectionFromTitle(s.Title);
                        steps.Add(new SignalingStep(
                            direction?.ToLowerInvariant() ?? "signal",
                            SignalingStepLabel(direction, s.Kind),
                            s.Details,
                            s.Timestamp));
                    }

                    if (completeEntry != null)
                    {
                        steps.Add(new SignalingStep(
                            "complete",
                            "Returned to agent",
                            isError ? completeEntry.Details : null,
                            completeEntry.Timestamp));
                    }

                    _signalingRenderData[toolCallId] = steps;
                    // Clear Input/Output — the custom renderer shows the full signaling flow
                    toolCall = new ToolCall { Id = toolCallId, ToolName = toolCall.ToolName, State = state };
                }

                if (pendingTools == null)
                {
                    pendingTools = new List<ToolCall>();
                    pendingStart = entry.Timestamp;
                }
                pendingTools.Add(toolCall);
                continue;
            }

            // Non-tool entries: flush any accumulated tool calls first
            FlushPendingTools();

            if (entry.Source == SessionTranscriptSource.Agent
                && entry.Kind == nameof(AgentActivityKind.AssistantMessage))
            {
                result.Add(new ChatMessage
                {
                    Role = MessageRole.Assistant,
                    Content = entry.Details ?? "",
                    Timestamp = entry.Timestamp,
                });
            }
            else if (entry.Source == SessionTranscriptSource.Agent
                && entry.Kind == nameof(AgentActivityKind.Idle))
            {
                // Idle events do not add value in the chat view
            }
            else if (entry.Source == SessionTranscriptSource.Agent
                && entry.Kind == nameof(AgentActivityKind.Error))
            {
                var errorText = entry.Details ?? "Agent error";
                result.Add(new ChatMessage
                {
                    Role = MessageRole.System,
                    Timestamp = entry.Timestamp,
                    CustomContent = b =>
                    {
                        b.OpenElement(0, "div");
                        b.AddAttribute(1, "class", "pbt-error-msg");
                        b.AddContent(2, errorText);
                        b.CloseElement();
                    },
                });
            }
            else
            {
                var capturedEntry = entry;
                result.Add(new ChatMessage
                {
                    Role = MessageRole.System,
                    Timestamp = entry.Timestamp,
                    RoleLabel = "",
                    ShowTimestamp = false,
                    CustomContent = b => RenderLifecycleEntry(b, capturedEntry),
                });
            }
        }

        FlushPendingTools();
        return result;
    }

    private static void RenderSignalingSteps(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, List<SignalingStep> steps)
    {
        int seq = 0;
        b.OpenElement(seq++, "div");
        b.AddAttribute(seq++, "class", "pbt-signaling-steps");
        foreach (var step in steps)
        {
            b.OpenElement(seq++, "div");
            b.AddAttribute(seq++, "class", $"pbt-sig-step pbt-sig-step--{step.StepKind}");

            b.OpenElement(seq++, "div");
            b.AddAttribute(seq++, "class", "pbt-sig-step-header");

            b.OpenElement(seq++, "span");
            b.AddAttribute(seq++, "class", "pbt-sig-step-arrow");
            b.AddContent(seq++, StepArrow(step.StepKind));
            b.CloseElement();

            b.OpenElement(seq++, "span");
            b.AddAttribute(seq++, "class", "pbt-sig-step-label");
            b.AddContent(seq++, step.Label);
            b.CloseElement();

            b.OpenElement(seq++, "span");
            b.AddAttribute(seq++, "class", "pbt-sig-step-time");
            b.AddContent(seq++, step.Time.ToLocalTime().ToString("HH:mm:ss.fff"));
            b.CloseElement();

            b.CloseElement(); // pbt-sig-step-header

            if (!string.IsNullOrEmpty(step.Payload))
            {
                b.OpenElement(seq++, "pre");
                b.AddAttribute(seq++, "class", "pbt-sig-step-payload");
                b.AddContent(seq++, step.Payload);
                b.CloseElement();
            }
            else
            {
                b.OpenElement(seq++, "div");
                b.AddAttribute(seq++, "class", "pbt-sig-step-empty");
                b.AddContent(seq++, "(no payload)");
                b.CloseElement();
            }

            b.CloseElement(); // pbt-sig-step
        }
        b.CloseElement(); // pbt-signaling-steps
    }

    private static void RenderLifecycleEntry(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b, SessionTranscriptEntry entry)
    {
        int seq = 0;
        b.OpenElement(seq++, "div");
        b.AddAttribute(seq++, "class", $"pbt-lifecycle {EntryKindClass(entry)}");

        b.OpenElement(seq++, "div");
        b.AddAttribute(seq++, "class", "pbt-lc-row");

        b.OpenElement(seq++, "span");
        b.AddAttribute(seq++, "class", "pbt-lc-source");
        b.AddContent(seq++, entry.Source.ToString());
        b.CloseElement();

        b.OpenElement(seq++, "span");
        b.AddAttribute(seq++, "class", "pbt-lc-kind");
        b.AddContent(seq++, entry.Kind);
        b.CloseElement();

        if (!string.IsNullOrEmpty(entry.Title))
        {
            b.OpenElement(seq++, "span");
            b.AddAttribute(seq++, "class", "pbt-lc-title");
            b.AddContent(seq++, entry.Title);
            b.CloseElement();
        }

        b.OpenElement(seq++, "span");
        b.AddAttribute(seq++, "class", "pbt-lc-time");
        b.AddContent(seq++, entry.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff"));
        b.CloseElement();

        b.CloseElement(); // pbt-lc-row

        if (!string.IsNullOrEmpty(entry.Details))
        {
            if (entry.Source == SessionTranscriptSource.Lifecycle && entry.Kind == "Prompt")
            {
                b.OpenElement(seq++, "details");
                b.AddAttribute(seq++, "class", "pbt-lc-details-toggle");
                b.OpenElement(seq++, "summary");
                b.AddContent(seq++, "Show system prompt");
                b.CloseElement();
                b.OpenElement(seq++, "pre");
                b.AddAttribute(seq++, "class", "pbt-lc-details");
                b.AddContent(seq++, entry.Details);
                b.CloseElement();
                b.CloseElement();
            }
            else if (entry.Source == SessionTranscriptSource.Lifecycle && entry.Kind == "Turn Started")
            {
                b.OpenElement(seq++, "details");
                b.AddAttribute(seq++, "class", "pbt-lc-details-toggle");
                b.AddAttribute(seq++, "open", true);
                b.OpenElement(seq++, "summary");
                b.AddContent(seq++, "Show tool prompt");
                b.CloseElement();
                b.OpenElement(seq++, "pre");
                b.AddAttribute(seq++, "class", "pbt-lc-details");
                b.AddContent(seq++, entry.Details);
                b.CloseElement();
                b.CloseElement();
            }
            else
            {
                b.OpenElement(seq++, "pre");
                b.AddAttribute(seq++, "class", "pbt-lc-details");
                b.AddContent(seq++, entry.Details);
                b.CloseElement();
            }
        }

        b.CloseElement(); // pbt-lifecycle
    }

    private static string StepArrow(string stepKind) => stepKind switch
    {
        "outbound" => "→",
        "inbound" => "←",
        "complete" => "↩",
        "params" => "⟶",
        _ => "•",
    };

    private static string StateClass(SessionState s) => s switch
    {
        SessionState.Active => "active",
        SessionState.Responding => "responding",
        SessionState.WaitingInput => "waiting",
        SessionState.Pooled => "pooled",
        SessionState.Crashed => "crashed",
        SessionState.Spawning => "spawning",
        _ => "other",
    };

    private static string EntryKindClass(SessionTranscriptEntry entry)
    {
        if (entry.Source == SessionTranscriptSource.Agent
            && entry.Kind == nameof(AgentActivityKind.AssistantMessage))
        {
            return "agent-message";
        }
        if (entry.Source == SessionTranscriptSource.Agent
            && entry.Kind == nameof(AgentActivityKind.Idle))
        {
            return "agent-idle";
        }
        if (entry.Source == SessionTranscriptSource.Lifecycle)
        {
            return entry.Kind switch
            {
                "Caller Invoked" => "lifecycle-caller",
                "Turn Started" => "lifecycle-turn-start",
                "Turn Ended" => "lifecycle-turn-end",
                "Input Received" => "lifecycle-input-received",
                "Spawned" or "Woken" => "lifecycle-session-up",
                "Pooled" or "Dropped" => "lifecycle-session-down",
                "Crashed" => "lifecycle-crashed",
                _ => string.Empty,
            };
        }
        return string.Empty;
    }

    private readonly record struct ToolPairing(
        Dictionary<int, int> StartToComplete,
        HashSet<int> SkipIndices,
        Dictionary<int, List<int>> StartToSignals);

    /// <summary>
    /// Builds a FIFO pairing between <see cref="AgentActivityKind.ToolStart"/> and
    /// <see cref="AgentActivityKind.ToolComplete"/> transcript entries that share
    /// the same tool name. Each ToolStart is paired with the next unmatched
    /// ToolComplete for the same tool. Signaling entries that fall inside a pair's
    /// interval (or after a pending start) are attached to that start so the
    /// renderer can present the full signaling exchange — outbound payload,
    /// inbound callback, and final return — under a single tool-call row.
    /// </summary>
    private static ToolPairing BuildToolPairs(IReadOnlyList<SessionTranscriptEntry> entries)
    {
        var pairs = new Dictionary<int, int>();
        var skip = new HashSet<int>();
        for (int i = 0; i < entries.Count; i++)
        {
            var e = entries[i];
            if (e.Source != SessionTranscriptSource.Agent
                || e.Kind != nameof(AgentActivityKind.ToolStart))
            {
                continue;
            }

            for (int j = i + 1; j < entries.Count; j++)
            {
                if (skip.Contains(j)) { continue; }
                var c = entries[j];
                if (c.Source == SessionTranscriptSource.Agent
                    && c.Kind == nameof(AgentActivityKind.ToolComplete)
                    && string.Equals(c.Title, e.Title, StringComparison.Ordinal))
                {
                    pairs[i] = j;
                    skip.Add(j);
                    break;
                }
            }
        }

        var startToSignals = new Dictionary<int, List<int>>();
        for (int i = 0; i < entries.Count; i++)
        {
            var s = entries[i];
            if (s.Source != SessionTranscriptSource.Signaling) { continue; }

            int? owner = null;
            for (int k = 0; k < i; k++)
            {
                var ke = entries[k];
                if (ke.Source != SessionTranscriptSource.Agent
                    || ke.Kind != nameof(AgentActivityKind.ToolStart))
                {
                    continue;
                }

                var endIdx = pairs.TryGetValue(k, out var ce) ? ce : entries.Count;
                if (endIdx > i && (owner == null || k > owner.Value))
                {
                    owner = k;
                }
            }

            if (owner is int ownerIdx)
            {
                if (!startToSignals.TryGetValue(ownerIdx, out var list))
                {
                    list = new List<int>();
                    startToSignals[ownerIdx] = list;
                }
                list.Add(i);
                skip.Add(i);
            }
        }

        return new ToolPairing(pairs, skip, startToSignals);
    }

    private static string? SignalingDirectionFromTitle(string? title)
    {
        if (string.IsNullOrEmpty(title)) return null;
        var slash = title.IndexOf(' ');
        return slash > 0 ? title[..slash] : title;
    }

    private static string SignalingStepLabel(string? direction, string kind) => direction switch
    {
        "Outbound" => $"Sent to caller ({kind})",
        "Inbound" => $"Received from caller ({kind})",
        _ => $"Signal ({kind})",
    };

    private static readonly HashSet<string> ThoughtToolNames = new(StringComparer.OrdinalIgnoreCase)
    {
        "report_intent",
        "think",
        "thought",
        "report_thought",
        "reasoning",
    };

    private static bool IsThoughtTool(string? toolName)
    {
        if (string.IsNullOrEmpty(toolName)) return false;
        return ThoughtToolNames.Contains(toolName);
    }

    private static readonly string[] ThoughtFieldNames = { "intent", "thought", "summary", "reasoning", "message", "text" };

    private static string? ExtractThoughtText(string? argumentsJson)
    {
        if (string.IsNullOrWhiteSpace(argumentsJson)) return null;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(argumentsJson);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object) return null;

            foreach (var field in ThoughtFieldNames)
            {
                if (doc.RootElement.TryGetProperty(field, out var prop)
                    && prop.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    var value = prop.GetString();
                    if (!string.IsNullOrWhiteSpace(value)) return value;
                }
            }
        }
        catch
        {
            // Fall through — caller will display raw JSON.
        }
        return null;
    }

    private static readonly System.Text.Json.JsonSerializerOptions TranscriptExportOptions = new()
    {
        WriteIndented = true,
        Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() },
    };

    public void Dispose()
    {
        Activity.EntryAdded -= OnEntryAdded;
        Activity.SessionsChanged -= OnSessionsChanged;
        cts?.Cancel();
        cts?.Dispose();
    }

    private sealed record SignalingStep(
        string StepKind,
        string? Label,
        string? Payload,
        DateTimeOffset Time);
}
